rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for matching)
      allow read: if request.auth != null;

      // Users can only create their own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can only update their own profile
      // Admins can update any profile (handled client-side via admin portal)
      allow update: if request.auth != null && request.auth.uid == userId;

      // No deletions allowed from client
      allow delete: if false;
    }

    // Jobs collection
    match /jobs/{jobId} {
      // Authenticated users can read jobs they're involved in
      // Clients can read their own jobs
      // Nurses can read jobs assigned to them
      // Admins can read all jobs
      allow read: if request.auth != null && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedNurseId == request.auth.uid
      );

      // Clients can create jobs
      allow create: if request.auth != null &&
        request.resource.data.clientId == request.auth.uid;

      // Clients can update their own jobs (before assignment)
      // Nurses can update status of assigned jobs
      // Admins can update any job
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedNurseId == request.auth.uid
      );

      // No deletions
      allow delete: if false;
    }
  }
}
