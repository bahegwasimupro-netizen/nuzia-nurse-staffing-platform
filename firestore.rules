rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      // Admins can read all profiles
      // Nurses can be read by anyone authenticated (for matching/display)
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin()
      );

      // Users can create their own profile on signup
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can update their own profile
      // Admins can update any profile (nurse availability, verification status, etc.)
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin()
      );

      // No deletions
      allow delete: if false;
    }

    // Jobs collection
    match /jobs/{jobId} {
      // Clients can read their own jobs
      // Nurses can read jobs assigned to them
      // Admins can read all jobs
      allow read: if request.auth != null && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedNurseId == request.auth.uid ||
        isAdmin()
      );

      // Clients can create jobs (must set their own clientId)
      allow create: if request.auth != null &&
        request.resource.data.clientId == request.auth.uid;

      // Clients can update their own jobs (payment, cancel)
      // Nurses can update status of assigned jobs (start travel, complete)
      // Admins can update any job (assignment, status overrides)
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedNurseId == request.auth.uid ||
        isAdmin()
      );

      // No deletions
      allow delete: if false;
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if request.auth != null && (
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if false;
    }

    // Messages collection (chat)
    match /chats/{chatId} {
      allow read, write: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid in request.resource.data.participants
      );
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid])
        );
        allow create: if request.auth != null;
      }
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.authorId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
